@startuml user-flow-guest-checkout
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 1. User Flow - Tamu ke Checkout Sukses (Guest to Completed Checkout)

start
:Masuk ke Beranda Little Joy;
:Membuka Katalog & Memilih Buket Bunga;
:Mengatur Kuantitas & Klik "Masukkan Ke Keranjang";
if (Apakah Tamu memiliki akun?) then (Tidak)
    :Mengisi Form Registrasi Baru;
    :Akun terdaftar otomatis;
else (Ya)
    :Memasukkan Email & Password;
    :Autentikasi sesi berhasil;
endif

:Membuka Keranjang Belanja;
:Memeriksa Rincian & Klik "Checkout";
:Mengisi Formulir Pengiriman\n(Penerima, Alamat, Tanggal Kirim, Pesan Kartu);
:Menekan Tombol "Konfirmasi Pesanan";

if (Apakah stok produk masih mencukupi?) then (Ya)
    :Sistem memproses data pesanan;\nNomor pesanan terbentuk (LJ-YYYYMMDD-XXXX);\nKeranjang belanja dikosongkan;
    :Melihat halaman Checkout Success\ndengan rincian instruksi rekening bank;
    stop
else (Tidak - Kehabisan)
    :Sistem menolak checkout;\nKembali ke keranjang belanja dengan pesan kesalahan;
    :Mengubah kuantitas / memilih produk lain;
    stop
endif
@enduml

