title 2. User Flow - Pelanggan Mengunggah Bukti Pembayaran

start
:Login ke akun Pelanggan;
:Mengakses halaman "Riwayat Pesanan";
:Memilih transaksi berstatus "Menunggu Pembayaran" / "Ditolak";
:Mengklik tombol "Upload Bukti Pembayaran";
:Mengisi Nama Pengirim, Bank Asal, Bank Tujuan, & Nominal;
:Memilih berkas gambar bukti transfer bank;
:Menekan tombol "Kirim Pembayaran";

if (Apakah format berkas gambar & ukuran <= 2MB?) then (Ya)
    :Sistem mengunggah gambar ke server;\nMembuat/update baris data di `payments`;\nMengubah status pesanan menjadi `waiting_verification`;
    :Melihat notifikasi sukses;\nStatus pesanan berubah menjadi "Menunggu Verifikasi";
    stop
else (Tidak - File Rusak/Besar)
    :Sistem menolak berkas;\nMenampilkan pesan validasi error di layar;
    :Memilih ulang berkas gambar bukti yang sesuai;
    stop
endif
@enduml

