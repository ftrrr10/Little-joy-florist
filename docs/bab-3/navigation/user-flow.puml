skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 3. User Flow - Operator Memverifikasi Bukti Pembayaran

start
:Login ke akun Operator / Admin;
:Mengakses Dashboard Operasional;
:Membuka antrean "Menunggu Verifikasi";
:Membuka detail pesanan terkait;
:Memeriksa validitas gambar bukti transfer & mutasi bank;

if (Apakah transfer dana valid & nominal sesuai?) then (Ya - Setujui)
    :Mengklik tombol "Verifikasi Pembayaran";
    if (Apakah stok produk mencukupi?) then (Ya)
        :Sistem memotong stok produk;\nSet status pembayaran = verified;\nSet status pesanan = paid;
        :Melihat status pesanan berubah menjadi "Lunas (Paid)";
        stop
    else (Tidak - Habis)
        :Sistem menggagalkan verifikasi;\nMenampilkan pesan kesalahan stok habis;
        stop
    endif
else (Tidak - Tolak)
    :Mengklik tombol "Tolak Pembayaran";
    :Menulis alasan penolakan pada kolom dialog;
    :Menekan tombol "Konfirmasi Tolak";
    :Sistem menyimpan alasan penolakan;\nSet status pembayaran = rejected;\nSet status pesanan = rejected;
    :Melihat status pesanan berubah menjadi "Ditolak";
    stop
endif
@enduml

