@startuml detailed-activity-login
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 2. Diagram Aktivitas Detail - Login Pengguna

|Pengguna|
start
:Membuka halaman Login;
:Menginput Email & Password;
:Menekan tombol "Masuk";

|Sistem (Laravel Backend)|
:Menerima Form Request Login;
:Memeriksa kecocokan email & hash password;
if (Kredensial cocok?) then (Tidak)
    :Mengirim respon error\n"Kredensial tidak cocok";
    |Pengguna|
    :Melihat pesan kesalahan & menginput ulang;
    stop
else (Ya)
endif

:Memeriksa status keaktifan akun (is_active);
if (Apakah is_active == true?) then (Tidak)
    :Mengeluarkan sesi (logout);\nMengarahkan ke login dengan pesan error\n"Akun dinonaktifkan";
    |Pengguna|
    :Melihat pesan penonaktifan;
    stop
else (Ya)
endif

:Membuat sesi login (*session token*);
:Memeriksa peran (*role*) pengguna;
if (Role == 'admin') then (Ya)
    :Mengarahkan ke Dashboard Admin;
else if (Role == 'operator') then (Ya)
    :Mengarahkan ke Dashboard Operator;
else (Customer)
    :Mengarahkan ke Beranda / Halaman Sebelumnya;
endif

|Pengguna|
:Menerima tampilan halaman tujuan sesuai hak akses;
stop
@enduml

