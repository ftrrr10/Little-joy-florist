@startuml detailed-activity-update-order-status
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 9. Diagram Aktivitas Detail - Pengelolaan Status Pesanan

|Operator / Admin|
start
:Membuka halaman Detail Pesanan aktif;
:Memilih status baru pada dropdown navigasi status;
:Menginput catatan operasional staf (*optional*);
:Menekan tombol "Perbarui Status";

|Sistem (Laravel Backend)|
:Memvalidasi kewenangan staf (*policy*);
:Mengambil status pesanan saat ini;
:Memeriksa validitas alur transisi status:
* `paid` -> `processing` (Mulai dirangkai)
* `processing` -> `ready` (Bunga selesai/siap)
* `ready` -> `shipped` (Bunga dikirim kurir)
* `shipped` -> `completed` (Pesanan selesai);

if (Apakah transisi status legal?) then (Ya)
    :Memperbarui kolom `order_status` di tabel `orders`;
    if (Status == 'completed') then (Ya)
        :Mengisi timestamp `completed_at` dengan waktu sekarang;
    else (Tidak)
    endif
    :Mencatat log riwayat transisi di `order_status_histories`;
    :Mengirim respon sukses ke antarmuka;
else (Tidak)
    :Menolak perubahan & mengirim respon error "Transisi Ilegal";
    |Operator / Admin|
    :Melihat pesan error & memilih alur yang benar;
    stop
endif

|Sistem (Laravel Backend)|
:Menyegarkan halaman detail pesanan;
|Operator / Admin|
:Melihat lini masa (*timeline*) status terupdate;
stop
@enduml

