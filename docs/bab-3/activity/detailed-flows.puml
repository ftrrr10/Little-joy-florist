@startuml detailed-activity-manage-product
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 10. Diagram Aktivitas Detail - Pengelolaan Produk Bunga (Admin CRUD)

|Admin|
start
:Mengakses halaman Manajemen Produk;

split
    :Menekan "Tambah Produk Baru";
    :Mengisi form nama, deskripsi, harga, stok, kategori,\nstatus aktif, & mengunggah gambar produk;
    :Menekan tombol "Simpan";
    |Sistem (Laravel Backend)|
    :Memvalidasi input (harga & stok >= 0, gambar < 2MB);
    if (Validasi sukses?) then (Ya)
        :Menyimpan gambar ke `public/products/` disk;
        :Membuat baris baru di tabel `products`;
    else (Tidak)
        :Kembali ke form dengan pesan error;
        stop
    fi
split again
    :Menekan tombol "Edit" pada produk;
    :Mengubah data produk & mengunggah gambar baru (*optional*);
    :Menekan tombol "Simpan Perubahan";
    |Sistem (Laravel Backend)|
    :Memvalidasi input;
    if (Validasi sukses?) then (Ya)
        if (Apakah gambar diganti?) then (Ya)
            :Menghapus berkas gambar lama dari penyimpanan server;
            :Menyimpan berkas gambar baru ke server;
        else (Tidak)
        endif
        :Memperbarui data produk di tabel `products`;
    else (Tidak)
        :Kembali ke form dengan pesan error;
        stop
    fi
split again
    :Menekan tombol "Hapus" pada salah satu produk;
    |Sistem (Laravel Backend)|
    :Menjalankan fungsi *Soft Delete* (`deleted_at = now()`);
    :Produk tidak akan muncul di katalog publik\nnamun data historis pesanan lama tetap aman;
end split

|Sistem (Laravel Backend)|
:Mengarahkan admin ke halaman daftar produk dengan pesan sukses;
|Admin|
:Melihat tabel produk terupdate;
stop
@enduml

