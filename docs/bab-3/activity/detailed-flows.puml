skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 7. Diagram Aktivitas Detail - Mengunggah Bukti Pembayaran

|Pelanggan|
start
:Membuka halaman Riwayat Pesanan;
:Memilih pesanan berstatus "Menunggu Pembayaran" / "Ditolak";
:Menekan tombol "Upload Bukti Pembayaran";
:Mengisi formulir (Bank Asal, Bank Tujuan, Nama Pengirim,\nNominal, Tanggal) & mengunggah berkas bukti (gambar);
:Menekan tombol "Kirim Pembayaran";

|Sistem (Laravel Backend)|
:Menerima Form Request Unggah Bukti;
:Memvalidasi data input & berkas bukti\n(ekstensi: JPG/JPEG/PNG/WebP, ukuran max: 2MB);

if (Validasi lolos?) then (Tidak)
    :Mengembalikan ke form dengan pesan error;
    |Pelanggan|
    :Memperbaiki form / memilih gambar baru;
    stop
else (Ya)
endif

:Membuka transaksi database;
if (Apakah sudah ada pembayaran sebelumnya yang ditolak?) then (Ya)
    :Menghapus berkas bukti transfer lama dari penyimpanan server;
    :Memperbarui baris data di tabel `payments`;
else (Tidak)
    :Menyimpan berkas bukti transfer baru ke `storage/app/public/payment_proofs/`;
    :Membuat baris data baru di tabel `payments` (status = 'waiting_verification');
endif

:Mengubah status pesanan menjadi `waiting_verification`;
:Mencatat histori status pesanan di `order_status_histories`;
:Komitmen Transaksi;
:Mengalihkan ke halaman detail pesanan dengan pesan sukses;

|Pelanggan|
:Melihat status pesanan diperbarui menjadi "Menunggu Verifikasi";
stop
@enduml

