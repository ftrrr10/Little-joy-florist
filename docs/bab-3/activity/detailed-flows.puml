skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 5. Diagram Aktivitas Detail - Memperbarui & Mengosongkan Keranjang

|Pelanggan|
start
:Mengakses halaman Keranjang Belanja;

split
    :Mengubah jumlah item (stepper +/-);
    |Sistem (Laravel Backend)|
    :Memeriksa kepemilikan item keranjang;
    if (Apakah milik user bersangkutan?) then (Tidak)
        :Aksi ilegal, aborsi (403 Forbidden);
        stop
    else (Ya)
    endif
    :Memvalidasi stok produk;
    if (Apakah stok cukup?) then (Ya)
        :Update kuantitas & kalkulasi subtotal;
        :Kirim flash session sukses;
    else (Tidak)
        :Kirim flash session error stok;
    fi
split again
    :Menekan tombol Hapus Item (ikon tempat sampah);
    |Sistem (Laravel Backend)|
    :Memeriksa kepemilikan item;
    :Menghapus baris item dari `cart_items`;
    :Kirim flash session sukses;
split again
    :Menekan tombol "Kosongkan Keranjang";
    |Sistem (Laravel Backend)|
    :Menghapus seluruh item terkait `cart_id`;
    :Kirim flash session sukses;
end split

|Sistem (Laravel Backend)|
:Memuat ulang data keranjang terupdate;\nMenghitung total tagihan akhir;
:Merender ulang halaman Keranjang;

|Pelanggan|
:Melihat tampilan keranjang yang telah diperbarui;
stop
@enduml

