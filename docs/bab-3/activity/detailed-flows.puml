@startuml detailed-activity-registration
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 1. Diagram Aktivitas Detail - Registrasi Pelanggan

|Pelanggan|
start
:Membuka halaman Registrasi;
:Menginput data Nama, Email, Telepon,\nAlamat, Password, & Konfirmasi Password;
:Menekan tombol "Daftar";

|Sistem (Laravel Backend)|
:Menerima Form Request Registrasi;
:Memvalidasi data input;
if (Apakah validasi sukses?) then (Tidak)
    :Mengirim respon error validasi\n(misal: format email salah, password terlalu pendek);
    |Pelanggan|
    :Melihat pesan error & memperbaiki input;
    stop
else (Ya)
endif

:Memeriksa apakah email sudah terdaftar;
if (Apakah email unik?) then (Tidak)
    :Mengirim respon error\n"Email sudah terdaftar";
    |Pelanggan|
    :Melihat pesan error & mengganti email;
    stop
else (Ya)
endif

:Meng-hash password menggunakan bcrypt;
:Menyimpan data pengguna baru ke database\n(role = 'customer', is_active = true);
:Membuat sesi login otomatis (*auto-authenticate*);
:Mengarahkan pengguna ke halaman Beranda\ndengan pesan sukses;

|Pelanggan|
:Menerima tampilan Beranda dengan kondisi login;
stop
@enduml

