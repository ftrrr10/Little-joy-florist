@startuml detailed-activity-add-to-cart
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 4. Diagram Aktivitas Detail - Memasukkan Produk Ke Keranjang

|Pelanggan|
start
:Membuka halaman Detail Produk;
:Menentukan jumlah (*quantity*) bunga;
:Menekan tombol "Masukkan Ke Keranjang";

|Sistem (Laravel Backend)|
if (Apakah pengguna sudah login?) then (Tidak)
    :Mengalihkan ke halaman Login;
    |Pelanggan|
    :Melakukan login;
    stop
else (Ya)
endif

:Memvalidasi input quantity;
:Mengambil data stok produk aktual dari database;
if (Apakah quantity <= stok?) then (Tidak)
    :Mengembalikan respon dengan pesan error\n"Stok tidak mencukupi";
    |Pelanggan|
    :Melihat pesan error & mengurangi jumlah;
    stop
else (Ya)
endif

:Membuka transaksi database;
:Mencari keranjang aktif milik pengguna;
if (Apakah keranjang sudah ada?) then (Tidak)
    :Membuat keranjang baru (`carts`);
else (Ya)
endif

:Memeriksa apakah produk sudah ada di keranjang;
if (Apakah produk duplikat?) then (Ya)
    :Menjumlahkan quantity lama dengan baru;\nMenghitung subtotal baru;
    :Memperbarui baris `cart_items`;
else (Tidak)
    :Membuat baris baru di `cart_items`;
endif
:Komitmen Transaksi;
:Mengarahkan pelanggan ke halaman Keranjang;

|Pelanggan|
:Melihat daftar barang belanjaan terupdate;
stop
@enduml

