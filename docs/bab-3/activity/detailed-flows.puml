@startuml detailed-activity-verify-reject-payment
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 8. Diagram Aktivitas Detail - Verifikasi atau Penolakan Pembayaran

|Operator / Admin|
start
:Membuka halaman Detail Pesanan di Dashboard;
:Memeriksa kesesuaian gambar bukti transfer dengan mutasi rekening bank;

if (Apakah pembayaran valid?) then (Ya - Setujui)
    :Menekan tombol "Verifikasi Pembayaran";
    |Sistem (Laravel Backend)|
    :Membuka transaksi database;
    :Mengunci baris produk terkait (`lockForUpdate`);
    :Memeriksa ketersediaan stok produk;
    if (Stok mencukupi?) then (Ya)
        :Mengurangi stok produk di tabel `products` secara otomatis;
        :Mencatat log mutasi keluar (`out`) di tabel `stock_movements`;
        :Memperbarui status di `payments` menjadi `verified`;
        :Memperbarui status di `orders` menjadi `paid`;
        :Mencatat transisi di `order_status_histories`;
        :Komitmen Transaksi;
    else (Tidak)
        :Membatalkan transaksi (*rollback*);\nMengirim respon error "Stok habis";
        |Operator / Admin|
        :Melihat pesan error verifikasi;
        stop
    endif
else (Tidak - Tolak)
    |Operator / Admin|
    :Menekan tombol "Tolak Pembayaran";
    :Menginputkan alasan penolakan wajib (*rejection_note*);
    :Mengirimkan form penolakan;
    |Sistem (Laravel Backend)|
    :Membuka transaksi database;
    :Memperbarui status di `payments` menjadi `rejected` & menyimpan alasan;
    :Memperbarui status di `orders` menjadi `rejected` (menunggu bukti baru);
    :Mencatat transisi di `order_status_histories`;
    :Komitmen Transaksi;
endif

|Sistem (Laravel Backend)|
:Menyegarkan halaman detail pesanan;
|Operator / Admin|
:Melihat status transaksi terbaru merefleksikan hasil keputusan;
stop
@enduml

