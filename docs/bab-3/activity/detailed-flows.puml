@startuml detailed-activity-stock-adjustment
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ActivityBackgroundColor #F7F4EB
skinparam ActivityBorderColor #022C22
skinparam ActivityFontColor #022C22
skinparam ArrowColor #10B981
skinparam StartColor #10B981
skinparam EndColor #EF4444
skinparam DiamondBackgroundColor #F7F4EB
skinparam DiamondBorderColor #022C22
skinparam DiamondFontColor #022C22

title 11. Diagram Aktivitas Detail - Penyesuaian Stok Manual (Koreksi Inventori)

|Operator / Admin|
start
:Membuka halaman Manajemen / Ringkasan Stok;
:Menekan tombol "Sesuaikan Stok" pada baris bunga;
:Mengisi formulir penyesuaian (Pilih Tambah / Kurang,\ninput jumlah selisih, & tulis alasan wajib);
:Menekan tombol "Simpan Penyesuaian";

|Sistem (Laravel Backend)|
:Menerima Form Request Penyesuaian Stok;
:Memvalidasi data input (selisih > 0, alasan tidak boleh kosong);

if (Validasi lolos?) then (Tidak)
    :Mengembalikan ke form dengan pesan error validasi;
    stop
else (Ya)
endif

:Membuka transaksi database (`DB::transaction`);
:Mengunci baris produk yang disesuaikan (`lockForUpdate`);
:Membaca stok produk saat ini;

if (Tipe penyesuaian == 'Kurang') then (Ya)
    :Menghitung stok akhir = stok saat ini - jumlah selisih;
    if (Apakah stok akhir < 0?) then (Ya)
        :Membatalkan transaksi (*rollback*);\nMengembalikan respon error "Stok akhir tidak boleh negatif";
        |Operator / Admin|
        :Melihat pesan error & mereset jumlah selisih;
        stop
    else (Tidak)
    endif
else (Tambah)
    :Menghitung stok akhir = stok saat ini + jumlah selisih;
endif

:Memperbarui kolom `stock` di tabel `products`;
:Menulis log audit di tabel `stock_movements`\n(product_id, type = 'adjustment', quantity = selisih,\nstock_before, stock_after, note, created_by = user_id);
:Komitmen Transaksi database;

:Mengirim respon sukses ke antarmuka;
|Operator / Admin|
:Melihat jumlah stok terupdate & baris log baru di riwayat mutasi;
stop
@enduml

