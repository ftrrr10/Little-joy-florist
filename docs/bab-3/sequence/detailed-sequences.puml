title 7. Sequence Diagram - Tambah Produk Baru (Admin CRUD)

actor "Administrator" as User
participant "admin/products/form.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "ProductController" as Controller
participant "ProductRequest" as Request
participant "ProductPolicy" as Policy
participant "Product (Model)" as ModelProduct
database "MySQL" as DB

User -> Page : Mengisi form produk & mengunggah foto bunga
User -> Page : Menekan tombol "Simpan"
Page -> Route : POST /admin/produk (data produk)
Route -> Controller : store(ProductRequest)
activate Controller

Controller -> Request : Validasi input form (harga, stok, format gambar)
activate Request
Request --> Controller : Validasi sukses
deactivate Request

Controller -> Policy : authorize('create', Product::class)
activate Policy
Policy --> Controller : Diizinkan (User adalah Admin)
deactivate Policy

Controller -> Controller : Unggah foto produk ke disk server (`storage/app/public/products/`)

Controller -> ModelProduct : create(data_produk_dan_foto)
activate ModelProduct
ModelProduct -> DB : INSERT `products` (nama, price, stock, image_path, is_active)
DB --> ModelProduct : Objek Produk Baru
ModelProduct --> Controller : Objek Produk Baru
deactivate ModelProduct

Controller --> Page : Redirect ke /admin/produk dengan flash success (Redirect Response)
deactivate Controller
Page --> User : Tampilkan daftar produk terbaru dengan baris baru tersemat
@enduml

