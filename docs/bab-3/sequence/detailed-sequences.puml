@startuml sequence-login
autonumber
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ParticipantBackgroundColor #F7F4EB
skinparam ParticipantBorderColor #022C22
skinparam ActorBackgroundColor #F7F4EB
skinparam ActorBorderColor #022C22
skinparam ArrowColor #10B981

title 1. Sequence Diagram - Login Pengguna

actor "Pengguna" as User
participant "login.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "LoginController" as Controller
participant "LoginRequest" as Request
database "MySQL" as DB

User -> Page : Membuka halaman login & input kredensial
User -> Page : Menekan tombol "Masuk"
Page -> Route : POST /login (data kredensial)
Route -> Controller : store(LoginRequest)
activate Controller

Controller -> Request : Melakukan validasi format input
activate Request
Request --> Controller : Validasi sukses
deactivate Request

Controller -> DB : Query user berdasarkan email
activate DB
DB --> Controller : Data Pengguna (email, password_hash, role, is_active)
deactivate DB

Controller -> Controller : Verifikasi kecocokan password (Hash::check)
Controller -> Controller : Verifikasi keaktifan akun (is_active == true)

alt Kredensial Valid & Akun Aktif
    Controller -> Controller : Regenerasi sesi (Auth::login)
    Controller --> Page : Redirect ke halaman tujuan (Redirect Response)
    Page --> User : Tampilan Dashboard / Beranda sesuai role
else Kredensial Salah / Akun Tidak Aktif
    Controller --> Page : Redirect back dengan pesan error (Redirect Back)
    deactivate Controller
    Page --> User : Tampilkan pesan kesalahan di form
end
@enduml

