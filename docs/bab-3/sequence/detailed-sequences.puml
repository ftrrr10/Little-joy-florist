title 4. Sequence Diagram - Mengunggah Bukti Pembayaran

actor "Pelanggan" as User
participant "payments/create.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "PaymentController" as Controller
participant "PaymentRequest" as Request
participant "Payment (Model)" as ModelPayment
database "MySQL" as DB

User -> Page : Memilih file bukti transfer & isi formulir bank
User -> Page : Menekan tombol "Kirim Pembayaran"
Page -> Route : POST /pesanan/{orderNumber}/pembayaran (data bukti)
Route -> Controller : store(orderNumber, PaymentRequest)
activate Controller

Controller -> Request : Validasi format gambar (<2MB) & input teks
activate Request
Request --> Controller : Validasi sukses
deactivate Request

Controller -> Controller : Validasi kepemilikan pesanan (auth_id == order->user_id)

Controller -> DB : DB::transaction()
activate DB

Controller -> Controller : Simpan file bukti ke folder `public/payment_proofs/`

alt Mengunggah Bukti Pertama Kali
    Controller -> ModelPayment : create(data_pembayaran)
    activate ModelPayment
    ModelPayment -> DB : INSERT `payments` (status = 'waiting_verification')
    ModelPayment --> Controller : Objek Pembayaran
    deactivate ModelPayment
else Unggah Ulang Karena Ditolak
    Controller -> Controller : Hapus berkas bukti transfer lama dari disk server
    Controller -> DB : UPDATE `payments` (bukti baru, status = 'waiting_verification')
end

Controller -> DB : UPDATE `orders` SET order_status = 'waiting_verification'
Controller -> DB : INSERT `order_status_histories` (catat waiting_verification)
Controller -> DB : Commit Transaction
deactivate DB

Controller --> Page : Redirect ke detail pesanan (Redirect Response)
deactivate Controller
Page --> User : Tampilan status pesanan berubah menjadi "Menunggu Verifikasi"
@enduml

