@startuml sequence-order-status-update
autonumber
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ParticipantBackgroundColor #F7F4EB
skinparam ParticipantBorderColor #022C22
skinparam ActorBackgroundColor #F7F4EB
skinparam ActorBorderColor #022C22
skinparam ArrowColor #10B981

title 6. Sequence Diagram - Pengelolaan Status Pesanan

actor "Operator / Admin" as User
participant "operator/orders/show.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "OperatorOrderController" as Controller
participant "Order (Model)" as ModelOrder
database "MySQL" as DB

User -> Page : Memilih status baru pada dropdown & klik "Perbarui Status"
Page -> Route : PUT /kelola/pesanan/{orderNumber}/status (status_baru, catatan)
Route -> Controller : updateStatus(orderNumber, Request)
activate Controller

Controller -> Controller : Validasi kewenangan peran (Operator/Admin)

Controller -> ModelOrder : where('order_number', orderNumber)->firstOrFail()
activate ModelOrder
ModelOrder -> DB : Query data pesanan
DB --> ModelOrder : Objek Pesanan
ModelOrder --> Controller : Objek Pesanan
deactivate ModelOrder

Controller -> Controller : Validasi keabsahan alur transisi status\n(contoh: dari 'paid' wajib ke 'processing')

alt Transisi Tidak Sah
    Controller --> Page : Redirect back dengan pesan error transisi ilegal (Redirect Back)
    Page --> User : Tampilkan peringatan alur tidak sesuai
else Transisi Sah
    Controller -> DB : DB::transaction()
    activate DB
    
    Controller -> DB : UPDATE `orders` SET order_status = status_baru
    
    alt Status == 'completed'
        Controller -> DB : UPDATE `orders` SET completed_at = now()
    end
    
    Controller -> DB : INSERT `order_status_histories` (catat status baru & operator_id)
    Controller -> DB : Commit Transaction
    deactivate DB
    
    Controller --> Page : Redirect back (Redirect Response)
    deactivate Controller
    Page --> User : Tampilan lini masa status terupdate secara dinamis
end
@enduml

