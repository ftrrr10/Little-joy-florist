@startuml sequence-add-to-cart
autonumber
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ParticipantBackgroundColor #F7F4EB
skinparam ParticipantBorderColor #022C22
skinparam ActorBackgroundColor #F7F4EB
skinparam ActorBorderColor #022C22
skinparam ArrowColor #10B981

title 2. Sequence Diagram - Memasukkan Produk Ke Keranjang

actor "Pelanggan" as User
participant "catalogue/show.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "CartController" as Controller
participant "CartItemRequest" as Request
participant "Product (Model)" as ModelProduct
participant "Cart (Model)" as ModelCart
database "MySQL" as DB

User -> Page : Menentukan jumlah & klik "Masukkan Ke Keranjang"
Page -> Route : POST /keranjang (product_id, quantity)
Route -> Controller : store(CartItemRequest)
activate Controller

Controller -> Request : Validasi request
activate Request
Request --> Controller : Validasi sukses
deactivate Request

Controller -> ModelProduct : findOrFail(product_id)
activate ModelProduct
ModelProduct -> DB : Query data produk
activate DB
DB --> ModelProduct : Data Produk (harga, stok, status)
deactivate DB
ModelProduct --> Controller : Objek Produk
deactivate ModelProduct

Controller -> Controller : Verifikasi quantity <= stok produk

Controller -> DB : DB::transaction()
activate DB

Controller -> ModelCart : firstOrCreate(['user_id' => auth_id])
activate ModelCart
ModelCart -> DB : Query / Insert keranjang milik user
DB --> ModelCart : Objek Keranjang
ModelCart --> Controller : Objek Keranjang
deactivate ModelCart

Controller -> DB : Query item duplikat di keranjang (`cart_items`)
DB --> Controller : Data item keranjang (jika ada)

alt Produk Sudah Ada di Keranjang
    Controller -> Controller : Hitung akumulasi quantity & subtotal baru
    Controller -> DB : UPDATE `cart_items` (quantity, subtotal)
else Produk Baru
    Controller -> DB : INSERT `cart_items` (cart_id, product_id, quantity, unit_price, subtotal)
end

Controller -> DB : Commit Transaction
deactivate DB

Controller --> Page : Redirect ke /keranjang (Redirect Response)
deactivate Controller
Page --> User : Tampilan halaman Keranjang Belanja terupdate
@enduml

