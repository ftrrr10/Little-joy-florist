@startuml sequence-payment-verification
autonumber
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ParticipantBackgroundColor #F7F4EB
skinparam ParticipantBorderColor #022C22
skinparam ActorBackgroundColor #F7F4EB
skinparam ActorBorderColor #022C22
skinparam ArrowColor #10B981

title 5. Sequence Diagram - Verifikasi Pembayaran (Oleh Operator/Admin)

actor "Operator / Admin" as User
participant "operator/orders/show.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "OperatorOrderController" as Controller
participant "Product (Model)" as ModelProduct
database "MySQL" as DB

User -> Page : Memeriksa mutasi bank & menekan tombol "Verifikasi Pembayaran"
Page -> Route : POST /kelola/pesanan/{orderNumber}/verifikasi-pembayaran
Route -> Controller : verifyPayment(orderNumber)
activate Controller

Controller -> DB : DB::transaction()
activate DB

Controller -> ModelProduct : lockForUpdate()->whereIn(order_items)->get()
activate ModelProduct
ModelProduct -> DB : SELECT ... FOR UPDATE (mengunci baris produk pesanan)
DB --> ModelProduct : Kumpulan Data Produk Terkunci
ModelProduct --> Controller : Kumpulan Objek Produk
deactivate ModelProduct

Controller -> Controller : Validasi kecukupan stok produk fisik

alt Stok Habis
    Controller -> DB : Rollback Transaction
    Controller --> Page : Redirect back dengan pesan error stok
    Page --> User : Tampilkan notifikasi kegagalan verifikasi (stok habis)
else Stok Cukup
    Controller -> DB : UPDATE `payments` SET verification_status = 'verified'
    Controller -> DB : UPDATE `orders` SET order_status = 'paid'
    Controller -> DB : UPDATE `products` SET stock = stock - quantity (potong stok otomatis)
    Controller -> DB : INSERT `stock_movements` (catat tipe mutasi 'out' dengan ref_id pesanan)
    Controller -> DB : INSERT `order_status_histories` (catat status 'paid')
    
    Controller -> DB : Commit Transaction
    deactivate DB
    
    Controller --> Page : Redirect back (Redirect Response)
    deactivate Controller
    Page --> User : Tampilan status pesanan berubah menjadi "Lunas (Paid)"
end
@enduml

