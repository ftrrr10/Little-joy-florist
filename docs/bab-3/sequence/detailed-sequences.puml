skinparam ParticipantBorderColor #022C22
skinparam ActorBackgroundColor #F7F4EB
skinparam ActorBorderColor #022C22
skinparam ArrowColor #10B981

title 8. Sequence Diagram - Penyesuaian Stok Bunga (Manual)

actor "Operator / Admin" as User
participant "operator/stock/index.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "StockController" as Controller
participant "Product (Model)" as ModelProduct
database "MySQL" as DB

User -> Page : Memilih tambah/kurang stok, isi kuantitas & alasan
User -> Page : Menekan tombol "Simpan Penyesuaian"
Page -> Route : POST /kelola/stok/penyesuaian (product_id, tipe, jumlah, catatan)
Route -> Controller : adjust(Request)
activate Controller

Controller -> Controller : Validasi input (catatan wajib, jumlah > 0)

Controller -> DB : DB::transaction()
activate DB

Controller -> ModelProduct : lockForUpdate()->findOrFail(product_id)
activate ModelProduct
ModelProduct -> DB : SELECT ... FOR UPDATE (kunci baris produk)
DB --> ModelProduct : Objek Produk Terkunci
ModelProduct --> Controller : Objek Produk Terkunci
deactivate ModelProduct

Controller -> Controller : Hitung kalkulasi stok akhir (sebelum +/- selisih)

alt Stok Akhir Negatif (< 0)
    Controller -> DB : Rollback Transaction
    Controller --> Page : Redirect back dengan pesan error stok negatif (Redirect Back)
    Page --> User : Tampilkan notifikasi "Penyesuaian dibatalkan, stok tidak boleh < 0"
else Stok Akhir Valid
    Controller -> DB : UPDATE `products` SET stock = stok_akhir
    Controller -> DB : INSERT `stock_movements` (catat tipe 'adjustment', log audit, & staff_id)
    Controller -> DB : Commit Transaction
    deactivate DB
    
    Controller --> Page : Redirect back (Redirect Response)
    deactivate Controller
    Page --> User : Tampilan jumlah stok & tabel histori log mutasi terupdate
end
@enduml

