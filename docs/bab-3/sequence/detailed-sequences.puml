@startuml sequence-checkout
autonumber
skinparam Style strictuml
skinparam DefaultFontName "Plus Jakarta Sans"
skinparam ParticipantBackgroundColor #F7F4EB
skinparam ParticipantBorderColor #022C22
skinparam ActorBackgroundColor #F7F4EB
skinparam ActorBorderColor #022C22
skinparam ArrowColor #10B981

title 3. Sequence Diagram - Proses Checkout Pesanan

actor "Pelanggan" as User
participant "checkout.blade.php (View)" as Page
participant "web.php (Route)" as Route
participant "CheckoutController" as Controller
participant "CheckoutRequest" as Request
participant "Product (Model)" as ModelProduct
participant "Order (Model)" as ModelOrder
database "MySQL" as DB

User -> Page : Mengisi formulir pengiriman & klik "Konfirmasi Pesanan"
Page -> Route : POST /checkout (data pengiriman)
Route -> Controller : store(CheckoutRequest)
activate Controller

Controller -> Request : Validasi input pengiriman
activate Request
Request --> Controller : Validasi sukses
deactivate Request

Controller -> DB : DB::transaction()
activate DB

Controller -> ModelProduct : lockForUpdate()->whereIn(product_ids)->get()
activate ModelProduct
ModelProduct -> DB : SELECT ... FOR UPDATE (mengunci baris produk)
DB --> ModelProduct : Kumpulan Data Produk Terkunci
ModelProduct --> Controller : Kumpulan Objek Produk
deactivate ModelProduct

Controller -> Controller : Validasi ketersediaan stok fisik produk\ndan kecocokan harga satuan aktual

alt Stok Tidak Cukup / Harga Berubah
    Controller -> DB : Rollback Transaction
    Controller --> Page : Redirect back dengan pesan error stok (Redirect Back)
    Page --> User : Tampilkan pesan error di Keranjang Belanja
else Stok Cukup
    Controller -> DB : Query pesanan hari ini untuk sequence nomor
    DB --> Controller : Data pesanan terakhir
    Controller -> Controller : Generate nomor pesanan (`LJ-YYYYMMDD-XXXX`)
    
    Controller -> ModelOrder : create(data_order)
    activate ModelOrder
    ModelOrder -> DB : INSERT `orders` (status = 'pending_payment')
    DB --> ModelOrder : Objek Pesanan Baru
    ModelOrder --> Controller : Objek Pesanan Baru
    deactivate ModelOrder

    Controller -> DB : INSERT `order_items` (menyalin snapshot produk & harga)
    Controller -> DB : DELETE `cart_items` (mengosongkan keranjang)
    Controller -> DB : INSERT `order_status_histories` (catat status pending_payment)
    
    Controller -> DB : Commit Transaction
    deactivate DB
    
    Controller --> Page : Redirect ke /checkout/sukses/{orderNumber}
    deactivate Controller
    Page --> User : Tampilkan halaman sukses checkout & panduan rekening bank
end
@enduml

